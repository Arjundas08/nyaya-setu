# ══════════════════════════════════════════════════════════════════
# NYAYA-SETU ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your actual values
# ══════════════════════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────────────────────

# Groq LLM API (FREE) — Get from https://console.groq.com
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.1-8b-instant

# MongoDB Atlas (FREE 512MB) — Get from https://cloud.mongodb.com
# Create free cluster → Connect → Drivers → Copy connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/nyayasetu?retryWrites=true&w=majority

# ── RECOMMENDED ───────────────────────────────────────────────────

# Indian Kanoon API — Get from https://api.indiankanoon.org/signup
# Provides access to 3 crore+ real Indian court judgments
# ₹500 free credit on signup
INDIANKANOON_API_KEY=your_indiankanoon_token_here

# ── OPTIONAL (Voice Features) ─────────────────────────────────────

# Bhashini API — Government of India voice services
# Get from https://bhashini.gov.in/ulca → My Profile → API Keys
# Supports: Hindi, Telugu, Tamil, Kannada, Bengali, Marathi, etc.
BHASHINI_USER_ID=your_user_id
BHASHINI_API_KEY=your_ulca_api_key
BHASHINI_INFERENCE_KEY=your_inference_api_key

# ══════════════════════════════════════════════════════════════════
# DEPLOYMENT NOTES
# ══════════════════════════════════════════════════════════════════
# 
# For Render/Railway deployment:
# - Add all above variables to your deployment platform's env vars
# - Do NOT commit the actual .env file to git
# - The .env.example file is safe to commit (contains no secrets)
#
# For local development:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual API keys
# 3. Run: uvicorn backend.main:app --port 8000
# 4. Run: streamlit run frontend/app.py --server.port 8501
# ══════════════════════════════════════════════════════════════════
